<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiet Siddur - Full Experience</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { transition: background-color 1s ease; font-family: 'Inter', sans-serif; background-color: #f8fafc; }
        .hebrew-text { 
            font-family: 'SBL Hebrew', serif; 
            line-height: 1.8; 
            direction: rtl; 
            font-size: 4rem; 
        }
        .english-text { font-size: 1.8rem; color: #475569; }
        .hidden { display: none; }
        .menu-btn { @apply w-full p-6 text-left text-xl bg-white border border-slate-200 rounded-2xl hover:bg-indigo-50 hover:border-indigo-300 transition-all mb-4 flex justify-between items-center; }
    </style>
</head>
<body id="mainBody" class="flex flex-col items-center justify-center min-h-screen p-6">

    <div id="checkin-card" class="max-w-xl w-full bg-white p-10 rounded-[40px] shadow-xl text-center">
        <h2 class="text-3xl font-light mb-6">How is your focus?</h2>
        <input type="range" id="anxietyScale" min="1" max="10" value="5" class="w-full h-4 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-indigo-500 mb-4">
        <div class="flex justify-between text-sm font-medium text-gray-400 mb-10">
            <span>1 (Calm)</span>
            <span>10 (Noisy)</span>
        </div>
        <button onclick="showMenu()" class="w-full py-5 bg-indigo-600 text-white rounded-2xl text-2xl font-bold">Open Siddur</button>
    </div>

    <div id="menu-screen" class="hidden w-full max-w-2xl">
        <h1 class="text-4xl font-bold mb-8 text-slate-800">What would you like to pray?</h1>
        <div id="menu-list">
            <button class="menu-btn shadow-sm" onclick="loadPrayer('Siddur_Ashkenaz%2C_Weekday%2C_Shacharit%2C_Preparation_for_Prayer%2C_Asher_Yatzar')">
                <span>Asher Yatzar</span> <span class="text-slate-300">→</span>
            </button>
            <button class="menu-btn shadow-sm" onclick="loadPrayer('Siddur_Ashkenaz%2C_Weekday%2C_Shacharit%2C_Shema')">
                <span>The Shema</span> <span class="text-slate-300">→</span>
            </button>
            <button class="menu-btn shadow-sm" onclick="loadPrayer('Siddur_Ashkenaz%2C_Weekday%2C_Shacharit%2C_Amidah%2C_Patriarchs')">
                <span>Amidah (Start)</span> <span class="text-slate-300">→</span>
            </button>
            <button class="menu-btn shadow-sm" onclick="loadPrayer('Siddur_Ashkenaz%2C_Weekday%2C_Shacharit%2C_Concluding_Prayers%2C_Aleinu_Leshabeach')">
                <span>Aleinu</span> <span class="text-slate-300">→</span>
            </button>
        </div>
        <button onclick="location.reload()" class="mt-8 text-slate-400 underline w-full">Back to Check-in</button>
    </div>

    <div id="prayer-interface" class="hidden w-full max-w-5xl">
        <div class="w-full bg-black/5 h-2 mb-12 rounded-full overflow-hidden">
            <div id="progressBar" class="bg-indigo-500 h-full transition-all duration-700" style="width: 0%"></div>
        </div>

        <div class="min-h-[500px] flex flex-col justify-center text-center">
            <div id="content" class="space-y-12">
                <p id="hebrew" class="hebrew-text font-bold text-slate-900"></p>
                <p id="english" class="english-text italic"></p>
            </div>

            <div class="mt-20 flex justify-between items-center">
                <button onclick="prevVerse()" class="text-xl text-slate-400">Back</button>
                <button onclick="nextVerse()" id="nextBtn" class="px-16 py-6 bg-indigo-600 text-white rounded-full text-2xl font-bold shadow-lg">Next Line</button>
            </div>
        </div>
    </div>

    <script>
        let lines = [];
        let currentIndex = 0;

        function showMenu() {
            const level = document.getElementById('anxietyScale').value;
            if (level >= 7) document.getElementById('mainBody').style.backgroundColor = "#f0f9ff";
            
            document.getElementById('checkin-card').classList.add('hidden');
            document.getElementById('menu-screen').classList.remove('hidden');
        }

        async function loadPrayer(sefariaPath) {
            lines = []; // Clear current prayer
            currentIndex = 0;
            
            // Show loading state
            document.getElementById('menu-screen').classList.add('hidden');
            document.getElementById('prayer-interface').classList.remove('hidden');
            document.getElementById('hebrew').innerText = "Loading...";

            try {
                const response = await fetch(`https://www.sefaria.org/api/texts/${sefariaPath}?context=0`);
                const data = await response.json();
                
                // Process lines (joining array and splitting by punctuation for focus)
                const rawHe = Array.isArray(data.he) ? data.he.join(' ') : data.he;
                const rawEn = Array.isArray(data.text) ? data.text.join(' ') : data.text;

                const heLines = rawHe.split(/[.:!]/);
                const enLines = rawEn.split(/[.:!]/);

                for(let i=0; i < heLines.length; i++) {
                    let h = heLines[i].replace(/<\/?[^>]+(>|$)/g, "").trim();
                    let e = enLines[i] ? enLines[i].replace(/<\/?[^>]+(>|$)/g, "").trim() : "";
                    
                    if(h.length > 3) {
                        lines.push({ he: h + ".", en: e + "." });
                    }
                }
                displayLine();
            } catch (e) {
                alert("Error loading prayer. Check your connection.");
            }
        }

        function displayLine() {
            if (lines.length === 0) return;
            document.getElementById('hebrew').innerText = lines[currentIndex].he;
            document.getElementById('english').innerText = lines[currentIndex].en;
            
            const progress = ((currentIndex + 1) / lines.length) * 100;
            document.getElementById('progressBar').style.width = `${progress}%`;
            
            if(currentIndex === lines.length - 1) document.getElementById('nextBtn').innerText = "Finish";
        }

        function nextVerse() {
            if (currentIndex < lines.length - 1) {
                currentIndex++;
                displayLine();
            } else {
                document.getElementById('prayer-interface').classList.add('hidden');
                document.getElementById('menu-screen').classList.remove('hidden');
            }
        }

        function prevVerse() {
            if (currentIndex > 0) {
                currentIndex--;
                displayLine();
            } else {
                document.getElementById('prayer-interface').classList.add('hidden');
                document.getElementById('menu-screen').classList.remove('hidden');
            }
        }
    </script>
</body>
</html>
